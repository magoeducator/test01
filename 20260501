let currentIdx = 0;
const userAnswers = {};
let userName = "";

function startQuiz() {
    const nameInput = document.getElementById('user-name').value.trim();
    if(!nameInput) {
        alert("이름을 입력해 주세요!");
        return;
    }
    userName = nameInput;
    document.getElementById('start-screen').style.display = 'none';
    document.getElementById('progress-area').style.display = 'block';
    document.getElementById('nav-area').style.display = 'flex';
    
    initQuiz();
}

function initQuiz() {
    const quizArea = document.getElementById('quiz-area');
    quizArea.innerHTML = '';

    quizData.forEach((data, index) => {
        const boxHtml = data.box ? `<div class="box-content">${data.box}</div>` : '';
        const categoryText = data.type === 'sonhai' ? '손해보험' : (data.type === 'automotive' ? '자동차보험' : (data.type === 'third' ? '제3보험' : '공통문항'));
        
        let optionsHtml = '';
        data.options.forEach((opt, oIdx) => {
            optionsHtml += `
                <button class="option-btn" id="q_${data.id}_o_${oIdx+1}" onclick="selectOption(${data.id}, ${oIdx+1})">
                    [${oIdx+1}] ${opt}
                </button>
            `;
        });

        const quizBox = document.createElement('div');
        quizBox.className = `quiz-box id-box-${data.id}`;
        if (index === 0) quizBox.classList.add('active');

        quizBox.innerHTML = `
            <div class="question">
                <span class="badge">${categoryText}</span>
                ${data.id}. ${data.q}
                <span class="score-badge">${data.score}점</span>
            </div>
            ${boxHtml}
            <div class="options">
                ${optionsHtml}
            </div>
        `;
        quizArea.appendChild(quizBox);
    });

    updateUI();
}

function selectOption(qId, optionNum) {
    userAnswers[qId] = optionNum;
    const currentBox = document.querySelector(`.id-box-${qId}`);
    const buttons = currentBox.querySelectorAll('.option-btn');
    buttons.forEach((btn, idx) => {
        if (idx === optionNum - 1) btn.classList.add('selected');
        else btn.classList.remove('selected');
    });
}

function updateUI() {
    const total = quizData.length;
    const progressPercent = ((currentIdx) / total) * 100;
    document.getElementById('progress-bar').style.width = `${progressPercent}%`;

    const boxes = document.querySelectorAll('.quiz-box');
    boxes.forEach((box, idx) => {
        if (idx === currentIdx) box.classList.add('active');
        else box.classList.remove('active');
    });

    document.getElementById('btn-prev').disabled = (currentIdx === 0);
    if (currentIdx === total - 1) {
        document.getElementById('btn-next').style.display = 'none';
        document.getElementById('btn-submit').style.display = 'block';
    } else {
        document.getElementById('btn-next').style.display = 'block';
        document.getElementById('btn-submit').style.display = 'none';
    }
}

function goNext() { if (currentIdx < quizData.length - 1) { currentIdx++; updateUI(); } }
function goPrev() { if (currentIdx > 0) { currentIdx--; updateUI(); } }

function submitQuiz() {
    if (!confirm("모든 문제를 제출하고 채점 결과를 확인하시겠습니까?")) return;

    let sonhaiScore = 0;
    let thirdScore = 0;
    let wrongSonhai = [];
    let wrongThird = [];

    quizData.forEach(item => {
        const userAns = userAnswers[item.id] || 0;
        const isCorrect = (userAns === item.ans);

        if (item.id >= 1 && item.id <= 33) {
            if (isCorrect) sonhaiScore += item.score;
            else wrongSonhai.push(item.id);
        }
        if (item.id >= 18 && item.id <= 50) {
            if (isCorrect) thirdScore += item.score;
            else wrongThird.push(item.id);
        }
    });

    document.getElementById('quiz-header').style.display = 'none';
    document.getElementById('progress-area').style.display = 'none';
    document.getElementById('quiz-area').style.display = 'none';
    document.getElementById('nav-area').style.display = 'none';
    document.getElementById('result-area').classList.add('active');

    document.getElementById('result-user-title').innerText = `👤 ${userName} 훈련생의 시험 결과`;
    document.getElementById('score-sonhai').innerText = `${sonhaiScore}점`;
    document.getElementById('score-3ins').innerText = `${thirdScore}점`;

    const sonhaiPass = sonhaiScore >= 60;
    const thirdPass = thirdScore >= 60;
    const isTotalPass = sonhaiPass && thirdPass;

    document.getElementById('res-sonhai').innerText = sonhaiPass ? "합격" : "과락";
    document.getElementById('res-sonhai').style.color = sonhaiPass ? "green" : "red";
    document.getElementById('res-3ins').innerText = thirdPass ? "합격" : "과락";
    document.getElementById('res-3ins').style.color = thirdPass ? "green" : "red";

    const passStatusDiv = document.getElementById('pass-status');
    passStatusDiv.innerText = isTotalPass ? "🎉 최종 합격입니다!" : "❌ 과락(탈락)입니다.";
