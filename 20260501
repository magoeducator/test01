    // 복사 박스용 요약 텍스트 구성
    let summaryText = `[한화손보 모의고사 5-1 결과]\n`;
    summaryText += `훈련생: ${userName}\n`;
    summaryText += `결과: ${isTotalPass ? '★최종합격★' : '불합격(과락)'}\n`;
    summaryText += `▶ 손해보험: ${sonhaiScore}점 (${sonhaiPass ? '합격':'과락'})\n`;
    summaryText += `▶ 제3보험: ${thirdScore}점 (${thirdPass ? '합격':'과락'})\n`;
    summaryText += `❌ 틀린 문항\n`;
    summaryText += `- 손보 틀린번호: ${wrongSonhai.length > 0 ? wrongSonhai.join(', ') + '번' : '없음'}\n`;
    summaryText += `- 제3보 틀린번호: ${wrongThird.length > 0 ? wrongThird.join(', ') + '번' : '없음'}`;

    // 텍스트 상자에 값 주입
    document.getElementById('output-text-area').value = summaryText;

    buildReviewNote();
}

function buildReviewNote() {
    const reviewArea = document.getElementById('review-area');
    reviewArea.innerHTML = '';

    quizData.forEach(item => {
        const userAns = userAnswers[item.id] || "미선택";
        const isCorrect = (userAnswers[item.id] === item.ans);
        
        const reviewItem = document.createElement('div');
        reviewItem.className = `review-item ${isCorrect ? '' : 'wrong'}`;

        const statusTxt = isCorrect 
            ? `<span style="color:green;">✔ 정답</span>` 
            : `<span class="txt-wrong">❌ 오답 (내 선택: [${userAns}]번)</span>`;

        reviewItem.innerHTML = `
            <div class="review-info">문항 ${item.id}번 | ${statusTxt}</div>
            <div style="font-weight:bold; margin-bottom:8px;">${item.q}</div>
            <div class="review-ans-box">
                <b>정답: [${item.ans}]번</b>
                <div class="explanation">💡 <b>공식 해설:</b> ${item.exp}</div>
            </div>
        `;
        reviewArea.appendChild(reviewItem);
    });
}
</script>
</body>
</html>
